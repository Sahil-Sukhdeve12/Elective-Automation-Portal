# Production Environment Variables
NODE_ENV=production
PORT=5000

# MongoDB Configuration (Update with your MongoDB Atlas URI)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/elective-selection

# JWT Secret (Use a strong, secure key in production)
JWT_SECRET=your_super_secure_jwt_secret_key_for_production

# CORS Origin (Update with your frontend domain)
CORS_ORIGIN=https://your-frontend-domain.vercel.app
