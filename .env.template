# Environment Variables
NODE_ENV=development
PORT=5000

# MongoDB Configuration - CHOOSE ONE OPTION:

# Option 1: Local MongoDB (if you install MongoDB locally)
# MONGODB_URI=mongodb://localhost:27017/elective-selection

# Option 2: MongoDB Atlas (Cloud - Recommended)
# Replace <username>, <password>, and <cluster-url> with your actual values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/elective-selection?retryWrites=true&w=majority

# JWT Secret (change this to a secure random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Client URL
CLIENT_URL=http://localhost:5173

# Instructions:
# 1. For MongoDB Atlas: Replace the MONGODB_URI with your actual connection string
# 2. For Local MongoDB: Uncomment the local MONGODB_URI line and comment out the Atlas one
# 3. Make sure to whitelist your IP address in MongoDB Atlas if using cloud option
